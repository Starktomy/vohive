# Documentation only. The installer creates /etc/vohive/config.yaml with a
# fresh random initial password and mode 0600. Never copy this example as an
# initialized production configuration.
config_schema: 1
server:
  host: 0.0.0.0
  port: 7575
data_dir: /var/lib/vohive/data
free_device_limit: 5
vowifi:
  enabled: false

# Public IP probes fall back in order, with at most four HTTPS endpoints per
# address family. Empty lists use the built-in defaults. Mainland China users
# may put trusted self-hosted dual-stack echo endpoints first.
# public_ip_probe:
#   ipv4_urls:
#     - https://your-ipv4-endpoint.example
#   ipv6_urls:
#     - https://your-ipv6-endpoint.example
