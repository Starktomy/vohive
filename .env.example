# Copy this file to .env. Resolve a stable or beta release tag to an immutable
# digest, then paste the full RepoDigest below:
#   docker pull ghcr.io/Starktomy/vohive:v1.6.0
#   docker image inspect --format='{{index .RepoDigests 0}}' ghcr.io/Starktomy/vohive:v1.6.0
VOHIVE_IMAGE=

# Optional host paths and timezone.
VOHIVE_CONFIG_DIR=./config
VOHIVE_DATA_DIR=./data
VOHIVE_LOG_DIR=./logs
TZ=UTC
